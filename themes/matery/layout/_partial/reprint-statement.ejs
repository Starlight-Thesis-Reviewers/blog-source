<%
let reprintPolicyEnabled = theme.reprint && theme.reprint.enable;
let reprintPolicy = page.reprintPolicy || theme.reprint.default || 'cc_by';
let url_matcher = 'https?://[-A-Za-z0-9+&@#/%?=~_|!:,.;]+[-A-Za-z0-9+&@#/%=~_|]';
%>
<% if (reprintPolicyEnabled) { %>
    <div class="reprint" id="reprint-statement">
        <% if (reprintPolicy === 'translation') { %>
            <div class="reprint__author">
                <span class="reprint-meta" style="font-weight: bold;">
                    <i class="fas fa-user"> 原文作者: </i>
                </span>
                <span class="reprint-info">
                    <%- page.author.name || '匿名' %>
                    <% if(page.author.url) { %>
                        <a href="<%- page.author.url %>" rel="external nofollow noreferrer" target="_blank">
                        <i class="<%- page.author.icon || theme.reprint.author_icon %>"></i>
                        </a>
                    <%} %>
                </span>
            </div>
            <div class="reprint__type">
                <span class="reprint-meta" style="font-weight: bold;">
                    <i class="fa-solid fa-link">原文链接: </i>
                </span>
                <span class="reprint-info">
                    <% if(page.origin_url && page.origin_url.match(url_matcher)) { %>
                        <a href="<%- page.origin_url %>" rel="external nofollow noreferrer" target="_blank"><%- page.origin_url %></a>
                    <% } else { %>
                        <%- page.origin_url || '未知' %>
                    <% } %>
                </span>
            </div>
            
            <div class="reprint__author">
                <span class="reprint-meta" style="font-weight: bold;">
                    <i class="fa-solid fa-book-open-reader"> 译者: </i>
                </span>
                <span class="reprint-info">
                    <%- page.translator.name || '匿名' %>
                    <% if(page.translator.url) { %>
                        <a href="<%- page.translator.url %>" rel="external nofollow noreferrer">
                        <i class="<%- page.translator.icon || theme.reprint.translator_icon %>"></i>
                        </a>
                    <%} %>
                </span>
            </div>
            <div class="reprint__notice">
                <span class="reprint-meta" style="font-weight: bold;">
                    <i class="fas fa-copyright">
                        <%= __('reprint') %>:
                    </i>
                </span>
                <span class="reprint-info">
                    本文一切版权归原文作者所有，如有侵权请联系删除。<br>
                    本記事の著作権はその著作者に帰属し、権利侵害となる場合はご連絡ください。
                </span>
            </div>
        <% } else if (reprintPolicy === 'cc_by') { %>
            <div class="reprint__author">
                <span class="reprint-meta" style="font-weight: bold;">
                    <i class="fas fa-user">
                        <%= __('author') %>:
                    </i>
                </span>
                <span class="reprint-info">
                    <a href="<%- url_for('/about') %>" rel="external nofollow noreferrer"><%- page.author || config.author %></a>
                </span>
            </div>
            <div class="reprint__type">
                <span class="reprint-meta" style="font-weight: bold;">
                    <i class="fas fa-link">
                        <%= __('link') %>:
                    </i>
                </span>
                <span class="reprint-info">
                    <a href="<%- config.url %><%- url_for(page.path) %>"><%- config.url %><%- url_for(page.path) %></a>
                </span>
            </div>
            <div class="reprint__notice">
                <span class="reprint-meta" style="font-weight: bold;">
                    <i class="fas fa-copyright">
                        <%= __('reprint') %>:
                    </i>
                </span>
                <span class="reprint-info">
                    <%= __('use') %>
                    <a href="<%= __('cc_by_url') %>" rel="external nofollow noreferrer" target="_blank"><%= __('cc_by_name') %></a>
                    <%= __('licensed') %>
                    <a href="<%- url_for('/about') %>" target="_blank"><%- page.author || config.author %></a>
                    !
                </span>
            </div>
        <% } else if (reprintPolicy === 'cc_by_nd') { %>
